page{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica Neue,Arial,sans-serif;font-size:28rpx;color:#333;background-color:#f5f7fa;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}.container{padding:24rpx;min-height:100vh;box-sizing:border-box}.card{background:#fff;border-radius:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);padding:24rpx;margin-bottom:24rpx}.btn-primary{background:linear-gradient(135deg,#1e88e5,#42a5f5);color:#fff;border:none;border-radius:16rpx;padding:16rpx 32rpx;font-size:28rpx;font-weight:500;text-align:center;transition:all .3s ease}.btn-primary:active{transform:scale(.98);opacity:.9}.btn-secondary{background:#eee;color:#666;border:none;border-radius:16rpx;padding:16rpx 32rpx;font-size:28rpx;text-align:center;transition:all .3s ease}.btn-secondary:active{background:#e0e0e0}.input-field{width:100%;height:88rpx;padding:0 24rpx;background:#f5f7fa;border-radius:16rpx;border:2rpx solid #F0F0F0;font-size:28rpx;box-sizing:border-box;transition:all .3s ease}.input-field:focus{border-color:#1e88e5;background:#fff}.textarea-field{width:100%;padding:16rpx 24rpx;background:#f5f7fa;border-radius:16rpx;border:2rpx solid #F0F0F0;font-size:28rpx;box-sizing:border-box;transition:all .3s ease}.textarea-field:focus{border-color:#1e88e5;background:#fff}.tag{display:inline-flex;align-items:center;padding:8rpx 16rpx;border-radius:8rpx;font-size:22rpx}.tag.tag-primary{background:rgba(30,136,229,.1);color:#1e88e5}.tag.tag-success{background:rgba(76,175,80,.1);color:#4caf50}.tag.tag-warning{background:rgba(255,193,7,.1);color:#ffc107}.tag.tag-error{background:rgba(244,67,54,.1);color:#f44336}.flex{display:flex}.flex.flex-col{flex-direction:column}.flex.items-center{align-items:center}.flex.justify-center{justify-content:center}.flex.justify-between{justify-content:space-between}.flex.flex-wrap{flex-wrap:wrap}.flex.gap-sm{gap:16rpx}.flex.gap-md{gap:24rpx}.text-primary{color:#1e88e5}.text-secondary{color:#666}.text-muted{color:#999}.text-success{color:#4caf50}.text-warning{color:#ffc107}.text-error{color:#f44336}.font-bold{font-weight:600}.font-medium{font-weight:500}.text-center{text-align:center}.mb-sm{margin-bottom:16rpx}.mb-md{margin-bottom:24rpx}.mt-sm{margin-top:16rpx}.mt-md{margin-top:24rpx}@keyframes fadeIn{0%{opacity:0;transform:translateY(20rpx)}to{opacity:1;transform:translateY(0)}}@keyframes pulse{0%,to{opacity:1}50%{opacity:.5}}@keyframes slideIn{0%{transform:translate(-100%)}to{transform:translate(0)}}.animate-fade-in{animation:fadeIn .3s ease-out}.animate-pulse{animation:pulse 2s ease-in-out infinite}.animate-slide-in{animation:slideIn .3s ease-out}
page::after{position:fixed;content:'';left:-1000px;top:-1000px;-webkit-animation:shadow-preload .1s;-webkit-animation-delay:3s;animation:shadow-preload .1s;animation-delay:3s}@-webkit-keyframes shadow-preload{0%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}100%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}}@keyframes shadow-preload{0%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}100%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}